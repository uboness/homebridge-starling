{
  "name": "@uboness/homebridge-starling",
  "version": "0.1.1",
  "author": "uboness",
  "publishConfig": {
    "@uboness:registry": "https://registry.npmjs.org "
  },
  "displayName": "Homebridge Starling",
  "description": "Homebridge plugin for Starling Home Hub (for Nest)",
  "license": "Apache-2.0",
  "keywords": [
    "homebridge-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/uboness/homebridge-starling"
  },
  "bugs": {
    "url": "https://github.com/uboness/homebridge-starling/issues"
  },
  "engines": {
    "node": "^18.20.4 || ^20.15.1 || ^22",
    "homebridge": "^1.11.4 || ^2.0.0-beta.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "files": [
    "tsconfig.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "dist",
    "config.schema.json"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "tsc",
    "cbuild": "pnpm run clean && pnpm run build",
    "watch": "pnpm run clean && tsc -w",
    "prepublishOnly": "pnpm run build",
    "release:bump": "commit-and-tag-version",
    "release:bump-minor": "commit-and-tag-version --release-as minor",
    "release:bump-major": "commit-and-tag-version --release-as major",
    "release:postbump": "pnpm run release:push && pnpm run release:publish",
    "release:push": "git push --follow-tags",
    "release:publish": "npm publish --access public",
    "release": "pnpm run release:bump && pnpm run release:push && pnpm run release:publish",
    "release-minor": "pnpm run release:bump-minor && pnpm run release:push && pnpm run release:publish",
    "release-major": "pnpm run release:bump-major && pnpm run release:push && pnpm run release:publish"
  },
  "devDependencies": {
    "@types/node": "^18.16.20",
    "commit-and-tag-version": "^12.7.1",
    "homebridge": "1.11.4",
    "homebridge-config-ui-x": "^5.22.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@homebridge/node-pty-prebuilt-multiarch",
      "@nestjs/core",
      "@scarf/scarf",
      "macos-temperature-sensor"
    ]
  }
}
